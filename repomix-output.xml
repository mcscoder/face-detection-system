import 'package:flutter/material.dart';
import 'package:image_picker/image_picker.dart';

import '../state/app_controller.dart';
import '../widgets/status_banner.dart';

class EnrollmentScreen extends StatefulWidget {
  const EnrollmentScreen({super.key, required this.controller});

  final AppController controller;

  @override
  State<EnrollmentScreen> createState() => _EnrollmentScreenState();
}

class _EnrollmentScreenState extends State<EnrollmentScreen> {
  final ImagePicker _picker = ImagePicker();
  final TextEditingController _personIdController = TextEditingController();

  int acceptedSamples = 0;
  String displayName = '';
  String personId = '';
  String? statusText;

  @override
  void dispose() {
    _personIdController.dispose();
    super.dispose();
  }

  Future<void> _createPerson() async {
    final person = await widget.controller.createPerson(
      displayName: displayName,
    );
    if (!mounted || person == null) return;
    setState(() {
      personId = person.id;
      _personIdController.text = person.id;
      acceptedSamples = 0;
      statusText = 'Person created. Add 3-5 face samples.';
    });
  }

  Future<void> _pickAndUpload(ImageSource source) async {
    try {
      final image = await _picker.pickImage(source: source, imageQuality: 90);
      if (!mounted || image == null) return;
      final bytes = await image.readAsBytes();
      if (!mounted) return;
      final template = await widget.controller.uploadEnrollmentSample(
        personId: personId,
        fileName: _fileName(image, 'enrollment.jpg'),
        bytes: bytes,
      );
      if (!mounted || template == null) return;
      setState(() {
        acceptedSamples++;
        final quality = template.qualityScore?.toStringAsFixed(2) ?? 'accepted';
        statusText = 'Sample accepted. Quality: $quality.';
      });
    } catch (_) {
      if (mounted)
        widget.controller.showMessage('Could not read selected image.');
    }
  }

  @override
  Widget build(BuildContext context) {
    final remaining = (3 - acceptedSamples).clamp(0, 3);
    return AnimatedBuilder(
      animation: widget.controller,
      builder: (context, _) {
        final state = widget.controller.value;
        final canEnroll = state.session?.canEnroll ?? false;
        final canAddSample = canEnroll &&
            !state.isBusy &&
            personId.isNotEmpty &&
            acceptedSamples < 5;
        return ListView(
          padding: const EdgeInsets.all(16),
          children: [
            Text('Enrollment', style: Theme.of(context).textTheme.titleLarge),
            const SizedBox(height: 12),
            TextField(
              decoration: const InputDecoration(labelText: 'Display name'),
              onChanged: (value) => setState(() => displayName = value.trim()),
            ),
            const SizedBox(height: 12),
            FilledButton.icon(
              onPressed: canEnroll && !state.isBusy && displayName.isNotEmpty
                  ? _createPerson
                  : null,
              icon: const Icon(Icons.person_add),
              label: Text(state.isBusy ? 'Working...' : 'Create Person'),
            ),
            const SizedBox(height: 12),
            TextField(
              controller: _personIdController,
              decoration: const InputDecoration(labelText: 'Person ID'),
              onChanged: (value) => setState(() {
                personId = value.trim();
                acceptedSamples = 0;
                statusText = null;
              }),
            ),
            const SizedBox(height: 16),
            LinearProgressIndicator(value: acceptedSamples / 5),
            const SizedBox(height: 8),
            Text(
                '$acceptedSamples accepted samples. $remaining more required.'),
            const SizedBox(height: 16),
            Row(
              children: [
                Expanded(
                  child: FilledButton.icon(
                    onPressed: canAddSample
                        ? () => _pickAndUpload(ImageSource.camera)
                        : null,
                    icon: const Icon(Icons.add_a_photo),
                    label: const Text('Camera'),
                  ),
                ),
                const SizedBox(width: 12),
                Expanded(
                  child: OutlinedButton.icon(
                    onPressed: canAddSample
                        ? () => _pickAndUpload(ImageSource.gallery)
                        : null,
                    icon: const Icon(Icons.photo_library),
                    label: const Text('Gallery'),
                  ),
                ),
              ],
            ),
            const SizedBox(height: 12),
            OutlinedButton.icon(
              onPressed: acceptedSamples >= 3
                  ? () => setState(() {
                        statusText = 'Enrollment ready for identify.';
                      })
                  : null,
              icon: const Icon(Icons.check_circle),
              label: const Text('Finish Enrollment'),
            ),
            const SizedBox(height: 16),
            if (state.message != null) ...[
              StatusBanner(label: state.message!, tone: BannerTone.error),
              const SizedBox(height: 12),
            ],
            if (!canEnroll) ...[
              const StatusBanner(
                label: 'Enrollment role required.',
                tone: BannerTone.warning,
              ),
              const SizedBox(height: 12),
            ],
            if (statusText != null) ...[
              StatusBanner(label: statusText!, tone: BannerTone.info),
              const SizedBox(height: 12),
            ],
            const StatusBanner(
              label:
                  'Samples should be clear, single-face images. Server performs quality checks.',
              tone: BannerTone.info,
            ),
          ],
        );
      },
    );
  }
}

String _fileName(XFile file, String fallback) {
  return file.name.isEmpty ? fallback : file.name;
}
